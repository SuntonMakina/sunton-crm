{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sunton CRM",
  "version": "0.1.0",
  "identifier": "com.sunton.crm",
  "build": {
    "frontendDist": "https://sunton-crm-mu.vercel.app",
    "devUrl": "http://localhost:3005",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Sunton CRM",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
